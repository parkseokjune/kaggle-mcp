# Copy to `.env` (gitignored) or export these in your shell / client config.
# Get a token at https://www.kaggle.com/settings -> API -> "Create New Token".
#
# The server supports BOTH credential schemes (resolved in this order):
#   1. legacy:  KAGGLE_USERNAME + KAGGLE_KEY   (or ~/.kaggle/kaggle.json)
#   2. token:   KAGGLE_API_TOKEN              (or ~/.kaggle/access_token, KGAT_... )
# Current Kaggle issues the KGAT_... token; save it to ~/.kaggle/access_token and
# the client reads it automatically — no env vars needed.

KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_40_char_api_key
# KAGGLE_API_TOKEN=KGAT_...

# Optional: isolate where the kaggle client looks for kaggle.json.
# KAGGLE_CONFIG_DIR=/abs/path/to/config-dir

# Optional: where downloads/extractions are sandboxed (defaults to a temp dir).
# KAGGLE_MCP_WORKDIR=/abs/path/to/work

# Optional safety switches (default OFF -> server is read-only/private-only).
# KAGGLE_MCP_ENABLE_DESTRUCTIVE=0   # set 1 to expose delete tools
# KAGGLE_MCP_ENABLE_PUBLISH=0       # set 1 to allow making datasets/kernels public
# KAGGLE_MCP_SUBMISSION_CAP=5       # daily per-competition submission budget
